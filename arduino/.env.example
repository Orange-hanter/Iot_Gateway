# Arduino Bridge Configuration Example
# Скопируйте этот файл в .env и настройте параметры

# === Device Configuration ===
# UUID вашего устройства из GatewayDemo (ОБЯЗАТЕЛЬНО)
DEVICE_ID=

# === Serial Port Configuration ===
# Путь к Serial порту (оставьте пустым для автопоиска)
# Linux/Mac: /dev/ttyUSB0, /dev/ttyACM0
# Windows: COM3, COM4
SERIAL_PORT=

# Скорость порта (не меняйте, если используете стандартную прошивку)
BAUD_RATE=115200

# === API Configuration ===
# URL API GatewayDemo
API_URL=http://localhost:8000/api/v1/ingest/http

# API ключ для аутентификации
API_KEY=your-secret-api-key-change-this

# === Logging ===
# Уровень логирования: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# Путь к файлу логов (опционально)
# LOG_FILE=/var/log/arduino-bridge.log
