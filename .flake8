[flake8]
# Strict rules aligned with ruff and black
max-line-length = 100
max-complexity = 10
exclude = .git,__pycache__,.venv,venv,env,.env,dist,build,.tox,.pytest_cache,*.egg-info,.mypy_cache,.ruff_cache,migrations

# Error codes to ignore
ignore = E203,E266,W503,F401,F403

# Select specific error codes for stricter checking
select = E,W,F,C,B

# Per-file ignores
per-file-ignores =
    __init__.py:F401,F403
    */tests/*:F841

# Enable all checks
count = True
statistics = True
show-source = True
