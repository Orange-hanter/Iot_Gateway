# Application
APP_NAME=IoT-Core
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_PATH=./data/iot_core.db
DATABASE_WAL_MODE=true
TELEMETRY_TTL_DAYS=30

# MQTT Broker
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883
MQTT_CLIENT_ID=iot-core-server
MQTT_TOPIC_PATTERN=iot/+/data
MQTT_QOS=1

# Security
API_KEY=your-secret-api-key-change-this
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-password
WEBHOOK_SECRET=your-webhook-secret

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
MAX_PAYLOAD_SIZE_KB=64

# Webhook
WEBHOOK_TIMEOUT_SECONDS=10
WEBHOOK_MAX_RETRIES=3
WEBHOOK_RETRY_DELAY_SECONDS=2

# Rule Engine
RULE_ENGINE_POLL_INTERVAL_SECONDS=5
TRIGGER_COOLDOWN_SECONDS=60
